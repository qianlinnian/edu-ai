# ===== 应用配置 =====
APP_NAME=EduAI Platform
DEBUG=true
SECRET_KEY=change-this-in-production-use-random-string

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://eduai:eduai123@postgres:5432/eduai
DATABASE_SYNC_URL=postgresql://eduai:eduai123@postgres:5432/eduai

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eduai

# ===== LLM - 通义千问（填入你的API Key）=====
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-flash
QWEN_VL_MODEL=qwen-vl-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ===== LLM - 智谱（备选）=====
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# ===== LLM - DeepSeek =====
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ===== 默认LLM提供者 =====
DEFAULT_LLM_PROVIDER=dashscope

# ===== Celery =====
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
